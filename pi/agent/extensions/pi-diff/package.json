{
	"name": "@heyhuynhgiabuu/pi-diff",
	"version": "0.1.6",
	"description": "Shiki-powered terminal diff renderer for pi — syntax-highlighted, word-level diffs in split and unified views.",
	"author": "huynhgiabuu",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/heyhuynhgiabuu/pi-diff.git"
	},
	"homepage": "https://github.com/heyhuynhgiabuu/pi-diff#readme",
	"bugs": {
		"url": "https://github.com/heyhuynhgiabuu/pi-diff/issues"
	},
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"diff",
		"syntax-highlighting",
		"shiki",
		"terminal"
	],
	"dependencies": {
		"diff": "^7.0.0",
		"@shikijs/cli": "^4.0.2"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"devDependencies": {
		"@types/diff": "^7.0.2",
		"@types/node": "^20.0.0",
		"typescript": "^5.0.0",
		"@biomejs/biome": "^2.3.5",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"lint:fix": "biome check --fix src/",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest --passWithNoTests"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	}
}
