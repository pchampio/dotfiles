#!/bin/bash
# Lookup command number for current scroll position
# Usage: tmux-prompt-lookup <pane_id>

pane="${1:-%0}"

# Get all values from tmux
# In copy-mode: scroll_position = lines scrolled up from bottom
# copy_cursor_y = cursor line on visible screen (0 = top)
# Absolute line = history_size - scroll_position + copy_cursor_y
eval "$(tmux display-message -t "$pane" -p 'hist=#{history_size};scroll=#{scroll_position};cursor_y=#{copy_cursor_y};map="#{@prompt_map}";total=#{@prompt_total}')"

[[ -z "$map" || -z "$total" || "$total" -eq 0 ]] && exit 0
[[ -z "$scroll" ]] && scroll=0
[[ -z "$cursor_y" ]] && cursor_y=0

# Current absolute line position (minus 2 to align with prompt)
current_line=$((hist - scroll + cursor_y + 2))

# Find the highest line number <= current_line
cmd=0
for entry in $map; do
    line=${entry%:*}
    num=${entry#*:}
    if [[ $line -le $current_line ]]; then
        cmd=$num
    else
        break
    fi
done

[[ $cmd -eq 0 ]] && exit 0
echo "$cmd/$total"
